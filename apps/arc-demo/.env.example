# Safe default: no hosted Coffer call, Circle call, or Arc write.
ARC_DEMO_MODE=mock
ARC_WRITE_ENABLED=false
CONFIRM_ARC_TESTNET_ONLY=

# Live Arc Testnet deployment (server-side only; never use NEXT_PUBLIC_).
ARC_RPC_URL=https://rpc.blockdaemon.testnet.arc.io
