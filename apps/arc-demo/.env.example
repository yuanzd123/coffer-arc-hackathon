ARC_DEMO_ACCESS_CODE=
ARC_DEMO_RUN_ID_ALLOW=
ARC_DEMO_RUN_ID_APPROVAL=
ARC_DEMO_RUN_ID_BLOCK=

CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_ARC_WALLET_ID=
CIRCLE_ARC_WALLET_ADDRESS=

COFFER_API_BASE_URL=https://app.cofferapi.com/api
COFFER_API_KEY=
COFFER_ARC_REGISTRY_ADDRESS=
COFFER_ARC_REGISTRY_DEPLOYMENT_BLOCK=
COFFER_ARC_FIXED_RECIPIENT=
